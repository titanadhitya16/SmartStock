<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="report_transaksiMasuk" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
  <parameter name="id_barang_masuk" class="java.lang.Integer"/>
  <parameter name="nm_supplier" class="java.lang.String"/>
  <queryString>
    <![CDATA[
      SELECT
          tm.tgl,
          tp.nama AS nama_petugas,
          ts.nama AS nama_supplier,
          tb.kode AS kode_barang,
          tb.nama AS nama_barang,
          tmd.jumlah
      FROM
          trbarang_masuk tm
      INNER JOIN
          trbarang_masuk_detail tmd ON tm.id_barang_masuk = tmd.id_barang_masuk
      INNER JOIN
          tmbarang tb ON tmd.id_barang = tb.id_barang
      INNER JOIN
          tmpetugas tp ON tm.id_petugas = tp.id_petugas
      INNER JOIN
          tmsupplier ts ON tm.id_supplier = ts.id_supplier
      WHERE
          tm.id_barang_masuk = $P{id_barang_masuk}
    ]]>
  </queryString>
  <field name="tgl" class="java.sql.Date"/>
  <field name="nama_petugas" class="java.lang.String"/>
  <field name="nama_supplier" class="java.lang.String"/>
  <field name="kode_barang" class="java.lang.String"/>
  <field name="nama_barang" class="java.lang.String"/>
  <field name="jumlah" class="java.lang.Integer"/>
  <detail>
    <band height="20">
      <textField>
        <reportElement x="0" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{tgl}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="100" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{nama_petugas}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="200" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{nama_supplier}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="300" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{kode_barang}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="400" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{nama_barang}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="500" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{jumlah}]]></textFieldExpression>
      </textField>
    </band>
  </detail>
</jasperReport>